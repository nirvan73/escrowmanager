generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  password      String
  name          String
  role          Role
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  projectsAsEmployer  Project[]    @relation("EmployerProjects")
  milestonesAssigned  Milestone[]  @relation("FreelancerMilestones")
  transactions        Transaction[]
  pfiScore            PFIScore?
}

enum Role {
  EMPLOYER
  FREELANCER
}

model Project {
  id            String        @id @default(uuid())
  title         String
  description   String
  budget        Float
  deadline      DateTime
  status        ProjectStatus @default(PENDING)
  employerId    String
  employer      User          @relation("EmployerProjects", fields: [employerId], references: [id])
  milestones    Milestone[]
  escrowAccount EscrowAccount?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

enum ProjectStatus {
  PENDING
  FUNDED
  IN_PROGRESS
  COMPLETED
  REFUNDED
  DISPUTED
}

model Milestone {
  id              String          @id @default(uuid())
  title           String
  description     String
  checklist       String[]
  amount          Float
  deadline        DateTime
  status          MilestoneStatus @default(PENDING)
  order           Int
  projectId       String
  project         Project         @relation(fields: [projectId], references: [id])
  freelancerId    String?
  freelancer      User?           @relation("FreelancerMilestones", fields: [freelancerId], references: [id])
  submissions     Submission[]
  transactions    Transaction[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  submissionType  SubmissionType @default(CODE)
  estimatedDays   Int?
}

enum MilestoneStatus {
  PENDING
  ASSIGNED
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  PARTIAL
  FAILED
  REFUNDED
}

model Submission {
  id              String           @id @default(uuid())
  milestoneId     String
  milestone       Milestone        @relation(fields: [milestoneId], references: [id])
  workDescription String
  repoUrl         String?
  aqaScore        Float?
  aqaDecision     AQADecision?
  aqaFeedback     String?
  aqaRawResponse  String?
  status          SubmissionStatus @default(PENDING)
  attemptNumber   Int              @default(1)
  createdAt       DateTime         @default(now())
}

enum AQADecision {
  FULL_PAYOUT
  PARTIAL_PAYOUT
  REFUND
}

enum SubmissionStatus {
  PENDING
  EVALUATED
  DISPUTED
}

model EscrowAccount {
  id                String        @id @default(uuid())
  projectId         String        @unique
  project           Project       @relation(fields: [projectId], references: [id])
  totalAmount       Float
  heldAmount        Float
  releasedAmount    Float         @default(0)
  refundedAmount    Float         @default(0)
  stripePaymentIntentId String?   @unique
  stripeCustomerId  String?
  status            EscrowStatus  @default(UNFUNDED)
  transactions      Transaction[]
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
}

enum EscrowStatus {
  UNFUNDED
  FUNDED
  PARTIALLY_RELEASED
  FULLY_RELEASED
  REFUNDED
}

model Transaction {
  id              String          @id @default(uuid())
  escrowAccountId String
  escrowAccount   EscrowAccount   @relation(fields: [escrowAccountId], references: [id])
  milestoneId     String?
  milestone       Milestone?      @relation(fields: [milestoneId], references: [id])
  userId          String?
  user            User?           @relation(fields: [userId], references: [id])
  type            TransactionType
  amount          Float
  stripeTransferId String?
  stripeRefundId  String?
  description     String
  createdAt       DateTime        @default(now())
}

enum SubmissionType {
    CODE
    DESIGN
    CONTENT
    DEPLOYMENT
}


enum TransactionType {
  ESCROW_FUND
  MILESTONE_PAYOUT
  PARTIAL_PAYOUT
  REFUND_EMPLOYER
  PLATFORM_FEE
}

model PFIScore {
  id                    String   @id @default(uuid())
  freelancerId          String   @unique
  freelancer            User     @relation(fields: [freelancerId], references: [id])
  overallScore          Float    @default(0)
  milestoneAccuracy     Float    @default(0)
  deadlineAdherence     Float    @default(0)
  averageAqaScore       Float    @default(0)
  totalMilestones       Int      @default(0)
  completedMilestones   Int      @default(0)
  failedMilestones      Int      @default(0)
  lastCalculatedAt      DateTime @default(now())
  updatedAt             DateTime @updatedAt
}
